    </Action>
    <Action Name="A_06_APin" Id="{21251d23-acba-466a-ae45-38d83c30d83e}">
      <Implementation>
        <ST><![CDATA[//Axis-BasicParameterSettings
//限位默认常闭，常开需要取反,白色常闭/黑色常开
arstAxis[6].wstrName:=" 顶pin轴" ;
arstAxis[6].strNetID:=stSystem.strNetID;//'192.168.1.50.2.1';
//arstAxis[6].Parameter.uiSlaveAddr:=1017;
arstAxis[6].State.bNSw:= TRUE ;// NC-White
arstAxis[6].State.bPSw:= TRUE;//
//false=etercat
// 功能块
fbAxis[6](AxisRef:=arAXIS[6] , stAxis:=arstAxis[6] , stSystem:=stSystem  , stHomeCoe:=arstHomeCoE[1],stHomeADS:=arstHomeADS[6]);]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_07_R1" Id="{c5033890-7e2d-49f7-bfa7-66a6b94544b3}">
      <Implementation>
        <ST><![CDATA[//Axis-BasicParameterSettings
//限位默认常闭，常开需要取反,白色常闭/黑色常开
arstAxis[7].wstrName:=" R1轴" ;
arstAxis[7].strNetID:=stSystem.strNetID;//'192.168.1.50.2.1';
//arstAxis[7].Parameter.uiSlaveAddr:=1017;
arstAxis[7].State.bNSw:=X001002 (*X001001 *);// NC-White
arstAxis[7].State.bPSw:=X001001 (* X001002;*);//
//false=etercat
// 功能块
fbAxis[7](AxisRef:=arAXIS[7] , stAxis:=arstAxis[7] , stSystem:=stSystem , stHomeCoe:=arstHomeCoE[1],stHomeADS:=arstHomeADS[7]);]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_08_R2" Id="{4cc5b5d8-e7ca-4a9c-b2e3-87feaf8bcfd1}">
      <Implementation>
        <ST><![CDATA[//Axis-BasicParameterSettings
//限位默认常闭，常开需要取反,白色常闭/黑色常开
arstAxis[8].wstrName:=" R2轴" ;
arstAxis[8].strNetID:=stSystem.strNetID;//'192.168.1.50.2.1';
//arstAxis[8].Parameter.uiSlaveAddr:=1017;
arstAxis[8].State.bNSw:= X001004(*X001003 *);// NC-White
arstAxis[8].State.bPSw:= X001003 (*X001004*);//
//false=etercat
// 功能块
fbAxis[8](AxisRef:=arAXIS[8] , stAxis:=arstAxis[8] , stSystem:=stSystem  , stHomeCoe:=arstHomeCoE[1],stHomeADS:=arstHomeADS[8]);]]></ST>
