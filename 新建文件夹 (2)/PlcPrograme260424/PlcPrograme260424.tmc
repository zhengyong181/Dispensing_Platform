TYPE ST_Vacuum :
STRUCT
    (* 输入 *)
    bVacuumReq     : BOOL;   // 抽真空请求
    bReleaseReq    : BOOL;   // 破真空请求
    xVacuumOk      : BOOL;   // 真空到位信号

    (* 输出 *)
