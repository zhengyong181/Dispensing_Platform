    <Action Name="ACT_COE" Id="{d857943d-9f32-4636-8947-3f5bca35d168}">
      <Implementation>
        <ST><![CDATA[
// 驱动器回零参数读取与写入	
	IF fbMcReadDistPerPulse.Valid AND fbMcReadGearRatio.Valid THEN
		udiHomeVelHigh := LREAL_TO_UDINT(rCMD_OffVelSetValue /(lrDistPerPulse / lrGearRatio));	
		udiHomeVelLow := LREAL_TO_UDINT(rCMD_TowardsVelSetValue /(lrDistPerPulse / lrGearRatio));
		diHomeOffset := LREAL_TO_DINT(rCMD_HomePosition /(lrDistPerPulse / lrGearRatio));
	END_IF;
		 
	//写入6098(HomingMethod)
	FB_EcCoESdoWrite_6098(
		sNetId:=stHomeCoEGroup.strNetID , 
		nSlaveAddr:=stHomeCoEGroup.wSlaveAddr , 
		nSubIndex:=16#00 , 
		nIndex:=16#6098 + (stHomeCoEGroup.uiAxisChannelNum - 1)*16#800  , 
		pSrcBuf:=ADR(bCMD_siHomeMethod) , 
		cbBufLen:=1 , 
		bExecute:= bSDO  , 
		tTimeout:= , 
		bBusy=> , 
		bError=> , 
		nErrId=> );

	//写入6099_01(HomeVelHigh)
	FB_EcCoESdoWrite_6099_01(
		sNetId:=stHomeCoEGroup.strNetID  , 
		nSlaveAddr:=stHomeCoEGroup.wSlaveAddr , 
		nSubIndex:=16#01 , 
		nIndex:=16#6099 + (stHomeCoEGroup.uiAxisChannelNum - 1)*16#800  , 
		pSrcBuf:=ADR(udiHomeVelHigh ) , 
		cbBufLen:=4 , 
		bExecute:= bSDO  , 
		tTimeout:= , 
		bBusy=> , 
		bError=> , 
		nErrId=> );	 
 
	//写入6099_02(HomeVelLow)
	FB_EcCoESdoWrite_6099_02(
		sNetId:=stHomeCoEGroup.strNetID   , 
		nSlaveAddr:=stHomeCoEGroup.wSlaveAddr , 
		nSubIndex:=16#02 , 
		nIndex:=16#6099 + (stHomeCoEGroup.uiAxisChannelNum- 1)*16#800  , 
		pSrcBuf:=ADR(udiHomeVelLow) , 
		cbBufLen:=4 , 
		bExecute:= bSDO , 
		tTimeout:= , 
		bBusy=> , 
		bError=> , 
		nErrId=> );

	//写入609A(HomeAcc)
//	FB_EcCoESdoWrite_609A(
//		sNetId:=stHomeCoEGroup.strNetID, 
//		nSlaveAddr:=stHomeCoEGroup.wSlaveAddr , 
//		nSubIndex:=16#00 , 
//		nIndex:=16#609A + (stHomeCoEGroup.uiAxisChannelNum - 1)*16#800  , 
//		pSrcBuf:=ADR(udiHomeAcc) , 
//		cbBufLen:=4 , 
//		bExecute:=bSDO , 
//		tTimeout:= , 
//		bBusy=> , 
//		bError=> , 
//		nErrId=> );	
	//写入607C (home offset）
	FB_EcCoESdoWrite_607C(
		sNetId:=stHomeCoEGroup.strNetID , 
		nSlaveAddr:=stHomeCoEGroup.wSlaveAddr , 
		nSubIndex:=16#00 , 
		nIndex:= 16#607C + (stHomeCoEGroup.uiAxisChannelNum - 1)*16#800 , 
		pSrcBuf:=ADR(diHomeOffset) , 
		cbBufLen:=SIZEOF(diHomeOffset) , 
		bExecute:=bSDO , 
		tTimeout:= , 
		bBusy=> , 
		bError=> , 
		nErrId=> );	
	//读取6041(Statusword)
	FB_EcCoESdoRead_6041(
		sNetId:=stHomeCoEGroup.strNetID , 
		nSlaveAddr:=stHomeCoEGroup.wSlaveAddr , 
		nSubIndex:=16#00 , 
		nIndex:=16#6041 + (stHomeCoEGroup.uiAxisChannelNum - 1)*16#800 , 
		pDstBuf:=ADR(uiStatusword) , 
		cbBufLen:=2 , 
		bExecute:=bSDOExe , 
		tTimeout:= , 
		bBusy=> , 
		bError=> , 
		nErrId=> );	
		
fbMcReadDistPerPulse(
	Axis:=axis , 
	Enable:= posEdge_bCMD_HomeExecute.Q, 
	ParameterNumber:=AxisEncoderScalingNumerator , 
	ReadMode:=READMODE_ONCE , 
	Value=>lrDistPerPulse );

fbMcReadGearRatio(
	Axis:= axis, 
	Enable:= posEdge_bCMD_HomeExecute.Q, 
	ParameterNumber:= AxisEncoderScalingDenominator,
	ReadMode:=READMODE_ONCE , 
	Value=>lrGearRatio );
	
fbMcWritePosMonitorEnable(
	Axis:=axis , 
	Execute:= bPosMonitorAbled, 
	ParameterNumber:= AxisEnPositionLagMonitoring, 
	Value:= 1, 
	Done=> , 
	Busy=> , 
	Error=> , 
	ErrorID=> );
fbMcWritePosMonitorDisable(
	Axis:= axis, 
	Execute:=bPosMonitorDisabled , 
	ParameterNumber:= AxisEnPositionLagMonitoring, 
	Value:= 0, 
	Done=> , 
	Busy=> , 
	Error=> , 
	ErrorID=> );]]></ST>
      </Implementation>
    </Action>
    <Action Name="ACT_Reset" Id="{b674516b-10fe-46de-9b12-9ebe63941794}">
      <Implementation>
        <ST><![CDATA[posEdge_bCMD_Reset(CLK:=bCMD_Reset);
ton_bCMD_Reset(IN:=bCMD_Reset,PT:=T#100MS);
ton_McReset(IN:=mcReset.Execute,PT:=T#100MS);
IF posEdge_bCMD_Reset.Q THEN
	bResult_HomeBusy:=FALSE;
	bResult_HomeDone:=FALSE;
	bResult_HomeError:=FALSE;
	nStep:=0;
	mcReset.Execute:=TRUE;
	mcMoveAbs.Execute:=FALSE;
ELSIF ton_bCMD_Reset.Q THEN
	bCMD_Reset:=FALSE;
END_IF

IF ton_McReset.Q THEN
	mcReset.Execute:=FALSE;
END_IF]]></ST>
      </Implementation>
    </Action>
