<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.12">
  <POU Name="FB_Drive_Home" Id="{bc4e0196-2980-4fb1-b36b-54f8ef2e08b0}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_Drive_Home
VAR_INPUT	
		bCMD_EnableState			:BOOL;						(* 使能状态输入*)	
		bCMD_siHomeMethod			:SINT;						(* 驱动器回圆方法*)
		bCMD_PositiveLimit			:BOOL;						(* 正限位传感器*)
		bCMD_NegativeLimit			:BOOL;						(* 负限位传感器*)
		rCMD_HomePosition			:LREAL;						(* 设定回原点位置*)
		rCMD_TowardsVelSetValue		:LREAL;						(* 靠近原点速度*)
		rCMD_OffVelSetValue			:LREAL;						(* 离开原点速度*)	
        bCMD_HomeExecute			:REFERENCE TO BOOL;			(* 执行回零*)
		bCMD_Reset					:REFERENCE TO BOOL;			(* 回零错误复位*)	
		stHomeCoEGroup				:ST_HomeCoEGroup;			(* coe信息*)
END_VAR
VAR_OUTPUT
	    bProcessPowerCtrl           :BOOL;
		bResult_HomeDone			:BOOL;						(* 回原点完成状态*)
		bResult_HomeBusy			:BOOL;						(* 正在回原点中状态*)
		bResult_HomeError			:BOOL;						(* 回原点错误状态*)
		nResult_HomeErrorID			:UDINT;						(* 回原点错误代码*)
END_VAR
VAR_IN_OUT
		axis						:AXIS_REF;
END_VAR
VAR
		mcHome						:MC_Home;
		mcReset						:MC_Reset;
		mcjog                       :MC_Jog;	
		mcMoveAbs					:MC_MoveAbsolute;
        FB_EcCoESdoWrite_6098:    FB_EcCoESdoWrite;
	    FB_EcCoESdoWrite_6099_01: FB_EcCoESdoWrite;
	    FB_EcCoESdoWrite_6099_02: FB_EcCoESdoWrite;
	    FB_EcCoESdoWrite_609A:    FB_EcCoESdoWrite;
	    FB_EcCoESdoWrite_607C:    FB_EcCoESdoWrite;
		uiStatusWord: UINT;
	    FB_EcCoESdoRead_6041: FB_EcCoESdoRead;
		fbReadParameter				:ARRAY [0..4] OF ADSREAD;
		fbwriteParameter			:ARRAY [0..4] OF ADSWRITE;
		rTowardsVelActValue			:LREAL;		
		rOffVelActValue				:LREAL;
		nHomeSenorSetValue			:INT;
		nHomeSensorActValue			:INT;
		nHomeSynSetValue			:WORD;
		nHomeSynActValue			:WORD;
		nHomeSetRefMode				:DINT;
		nHomeActRefMode				:DINT;
		mcHomeStatus				:ST_McOutputs;
		fbReadParaStatus			:ARRAY [0..4] OF ST_McOutputs;
		fbWriteParaStatus			:ARRAY [0..4] OF ST_McOutputs;
		posEdge_bCMD_HomeExecute	:R_TRIG;
		posEdge_bCMD_Reset			:R_TRIG;
		negEdge_bCMD_Calibration	:F_TRIG;
		ton_bCMD_HomeExecute		:TON;
		ton_nStep					:TON;
		ton_bCMD_Reset				:TON;
		ton_McReset					:TON;
		ton_HomErr                  :TON;
		nStep						:INT;
		
		
		fbEcCoESdoReadErrCode: FB_EcCoESdoRead                      ;           // 读COE 力矩
	    fbEcCoESdoWriteHMethod: FB_EcCoESdoWrite                  ;           // 写COE 回零方法
	    fbEcCoESdoWriteHOffset: FB_EcCoESdoWrite                  ;           // 写COE 回零偏置
	    fbEcCoESdoWriteHVelo: FB_EcCoESdoWrite                    ;           // 写COE 回零速度
		
	     fbMcReadDistPerPulse: MC_ReadParameter;
	     fbMcReadGearRatio: MC_ReadParameter;
	     fbMcWritePosMonitorDisable: MC_WriteParameter;
	     fbMcWritePosMonitorEnable: MC_WriteParameter;
	         // 每脉冲移动量
	      lrDistPerPulse: LREAL := 0.0001;
	        // 减速比
	      lrGearRatio: LREAL := 1;
				udiHomeVelHigh: UDINT;
	      udiHomeVelLow: UDINT;
	      diHomeOffset: DINT;
		  bSDO:BOOL;
		  bSDOExe:BOOL;
		  Ton07: TON;
		  Ton61: TON;
		  Ton62: TON;
		  blink10ms:BLINK;
		  bPosMonitorDisabled: BOOL;
	      bPosMonitorAbled: BOOL;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[posEdge_bCMD_HomeExecute(CLK:=bCMD_HomeExecute AND bCMD_EnableState AND NOT bResult_HomeError AND NOT bResult_HomeBusy);
ton_bCMD_HomeExecute(IN:=bCMD_HomeExecute,PT:=T#100MS);

IF posEdge_bCMD_HomeExecute.Q  THEN
	nStep:=1;
ELSIF	ton_bCMD_HomeExecute.Q THEN
	 bCMD_HomeExecute:=FALSE;
END_IF
// 超时定时器
ton_HomErr(IN:=bResult_HomeBusy , PT:=T#20S , Q=> , ET=> );
IF bCMD_siHomeMethod=0 AND bCMD_NegativeLimit AND ton_HomErr.Q THEN
		mcReset.Execute:=TRUE;
		nStep:=999;
ELSIF bCMD_siHomeMethod=1 AND bCMD_PositiveLimit AND ton_HomErr.Q THEN
		mcReset.Execute:=TRUE;
		nStep:=999;
END_IF
//触发读取写入SDO
			blink10ms(ENABLE:= , TIMELOW:= TIME#10MS , TIMEHIGH:= TIME#10MS , OUT=> bSDOExe);	
			IF nStep = 31 OR nStep = 35  THEN
				blink10ms.ENABLE := TRUE ; //循环触发，直到写入完成
			ELSE
				blink10ms.ENABLE := FALSE ;
			END_IF
			Ton07(IN:=( nStep = 15 OR nStep =20 OR  nStep = 25  OR nStep = 30), PT:=TIME#1000MS , Q=> , ET=> );
			Ton61(IN:=(nStep = 40),PT:=TIME#100MS,);
			Ton62(IN:=(nStep = 16),PT:=TIME#1000MS,);
			CASE nStep OF 
				1: 				    
					mcReset.Execute := FALSE ;
					nStep := 5 ;
				5: 
					bPosMonitorDisabled := TRUE;
					bPosMonitorAbled := FALSE;
					mcReset.Execute := TRUE ;
					IF mcReset.Done AND fbMcWritePosMonitorDisable.Done THEN
						mcReset.Execute := FALSE ;
						bPosMonitorDisabled := FALSE;
						nStep := 10 ;		 
					END_IF
				10:// 断使能
					 IF axis.Status.NotMoving AND axis.Status.StandStill THEN
                       bProcessPowerCtrl:=FALSE;
					   nStep := 15 ;
                     END_IF		 
				15:// 切换模式字，设定为6
					bCMD_siHomeMethod := 6 ;
					IF Ton07.Q  THEN
						nStep := 16 ;		 
					END_IF
				16: // 写入COE参数
				    bSDO:=TRUE;
					IF TON62.Q  THEN
						nStep:=20;
						bSDO:=FALSE;
					END_IF;
				20:// 重新使能
					 bProcessPowerCtrl:=TRUE;
					IF Ton07.Q AND bCMD_EnableState THEN
						nStep := 21;
					END_IF
				21:
					nStep := 25;
				25:// 复位
					mcReset.Execute := TRUE ;
					IF Ton07.Q AND mcReset.Done THEN
						nStep := 26;
					END_IF	
				26:// 	
						nStep:=30;
					
				30://					
					IF Ton07.Q THEN
						nStep := 31;
					END_IF;
				31:
					nStep :=35;
				35://等待状态字反馈 , 10 - Target Reached , 12 - Homing Attained , 13 - Homing Error
					IF uiStatusWord.10 AND uiStatusWord.12 AND NOT uiStatusWord.13 THEN
						mcReset.Execute :=TRUE;
						nStep:=36;
					END_IF
				36:
					IF mcReset.Done THEN
						mcReset.Execute := FALSE;
						bCMD_siHomeMethod :=8;
						nStep :=40;
					END_IF;
				40:	
					mcMoveAbs.Velocity:= REAL#2.0;
					IF Ton61.Q THEN
						mcMoveAbs.Execute:=TRUE;
					END_IF;
					IF mcMoveAbs.Done THEN
						mcMoveAbs.Execute:=FALSE;
						nStep := 50;	 
					END_IF	
				50:
					bPosMonitorDisabled := FALSE;
					bPosMonitorAbled := TRUE;
					IF fbMcWritePosMonitorEnable.Done THEN
						bPosMonitorAbled := FALSE;
						nStep := 60 ;
					END_IF;
				60:	
					bSDO:=FALSE;											
					bResult_HomeBusy := FALSE ;
					bResult_HomeDone := TRUE ;	
                    bResult_HomeError:= FALSE;				
					nStep := 0 ;		
				999:	 
				   	bSDO:=FALSE;											
					bResult_HomeBusy := FALSE ;
					bResult_HomeDone := FALSE ;
					bResult_HomeError:= TRUE;
					nStep := 0 ;	
			END_CASE	
ACT_AxisControl();
ACT_COE();
ACT_Reset();
]]></ST>
    </Implementation>
