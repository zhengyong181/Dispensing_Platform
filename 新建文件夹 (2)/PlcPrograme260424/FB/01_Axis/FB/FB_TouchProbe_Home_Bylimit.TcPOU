<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.12">
  <POU Name="FB_TouchProbe_Home_Bylimit" Id="{2ef58b1e-4663-40e7-8041-e93620483a0f}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK FB_TouchProbe_Home_Bylimit
VAR_INPUT	
		bCMD_HomeExecute			:REFERENCE TO BOOL;			(* 执行回零*)
		bCMD_Reset					:REFERENCE TO BOOL;			(* 回零错误复位*)
		bCMD_EnableState			:BOOL;						(* 使能状态输入*)	
		bCMD_StartHomeIndex			:BOOL;						(* 是否使用索引回零*)
		eCMD_HomeDirection			:MC_Direction;				(* 回原点方向*)
		bCMD_PositiveLimit			:BOOL;						(* 正限位传感器*)
		bCMD_NegativeLimit			:BOOL;						(* 负限位传感器*)
		rCMD_HomePosition			:LREAL;						(* 设定回原点位置*)
		rCMD_TowardsVelSetValue		:LREAL;						(* 靠近原点速度*)
		rCMD_OffVelSetValue			:LREAL;						(* 离开原点速度*)
	    stHomeAdsGroup				:ST_HomeAdsGroup;			(* ADS地址信息*)

END_VAR
VAR_OUTPUT
		bResult_HomeDone			:BOOL;						(* 回原点完成状态*)
		bResult_HomeBusy			:BOOL;						(* 正在回原点中状态*)
		bResult_HomeError			:BOOL;						(* 回原点错误状态*)
		nResult_HomeErrorID			:UDINT;						(* 回原点错误代码*)
END_VAR
VAR_IN_OUT
		axis						:AXIS_REF;
END_VAR
VAR
	  
		mcHome						:MC_Home;
		mcReset						:MC_Reset;
		fbReadParameter				:ARRAY [0..4] OF ADSREAD;
		fbwriteParameter			:ARRAY [0..4] OF ADSWRITE;
		rTowardsVelActValue			:LREAL;		
		rOffVelActValue				:LREAL;
		nHomeSenorSetValue			:INT;
		nHomeSensorActValue			:INT;
		nHomeSynSetValue			:WORD;
		nHomeSynActValue			:WORD;
		nHomeSetRefMode				:DINT;
		nHomeActRefMode				:DINT;
		mcHomeStatus				:ST_McOutputs;
		fbReadParaStatus			:ARRAY [0..4] OF ST_McOutputs;
		fbWriteParaStatus			:ARRAY [0..4] OF ST_McOutputs;
		posEdge_bCMD_HomeExecute	:R_TRIG;
		posEdge_bCMD_Reset			:R_TRIG;
		negEdge_bCMD_Calibration	:F_TRIG;
		ton_bCMD_HomeExecute		:TON;
		ton_nStep					:TON;
		ton_bCMD_Reset				:TON;
		ton_McReset					:TON;
		ton_HomErr                  :TON;
		nStep						:E_HomeStep;
		mcMoveAbs					:MC_MoveAbsolute;
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[posEdge_bCMD_HomeExecute(CLK:=bCMD_HomeExecute AND bCMD_EnableState AND NOT bResult_HomeError AND NOT bResult_HomeBusy);
ton_bCMD_HomeExecute(IN:=bCMD_HomeExecute,PT:=T#100MS);

IF posEdge_bCMD_HomeExecute.Q  THEN
	nStep:=AckHomeDirection;
ELSIF	ton_bCMD_HomeExecute.Q THEN
	 bCMD_HomeExecute:=FALSE;
END_IF


IF eCMD_HomeDirection=MC_Direction.MC_Positive_Direction  THEN
	mcHome.bCalibrationCam:=bCMD_PositiveLimit;
ELSIF eCMD_HomeDirection=MC_Direction.MC_Negative_Direction THEN
		mcHome.bCalibrationCam:=bCMD_NegativeLimit;
END_IF

CASE nStep OF
IndexHomeInital:
	ton_nStep(IN:=FALSE);		
	bResult_HomeBusy:=FALSE;
	mcHome.Execute:=FALSE;
	mcMoveAbs.Execute:=FALSE;
	fbReadParameter[0].READ:=fbReadParameter[1].READ:=fbReadParameter[2].READ:=fbReadParameter[3].READ:=fbReadParameter[4].READ:=FALSE;
	fbwriteParameter[0].WRITE:=fbwriteParameter[1].WRITE:=fbwriteParameter[2].WRITE:=fbwriteParameter[3].WRITE:=fbwriteParameter[4].WRITE:=FALSE;
	IF axis.Status.Error OR mcHome.Error THEN
		nStep:=IndexHomeErrorState;
	END_IF
AckHomeDirection:
	bResult_HomeBusy:=TRUE;
	bResult_HomeDone:=FALSE;
	IF bCMD_StartHomeIndex THEN
		nHomeSetRefMode:=2;
	ELSE
		nHomeSetRefMode:=0;  
	END_IF
	IF eCMD_HomeDirection=MC_Direction.MC_Positive_Direction   THEN
		nHomeSenorSetValue:=0;
		nHomeSynSetValue:=1;
		nStep:=SetParameter;
	ELSIF eCMD_HomeDirection=MC_Direction.MC_Negative_Direction THEN
		nHomeSenorSetValue:=1;
		nHomeSynSetValue:=0;
		nStep:=SetParameter;
	ELSE
		nStep:=IndexHomeErrorState;
	END_IF
SetParameter:
	fbwriteParameter[0].WRITE:=fbwriteParameter[1].WRITE:=fbwriteParameter[2].WRITE:=
	fbwriteParameter[3].WRITE:=fbwriteParameter[4].WRITE:=TRUE;
	nStep:=SetParameterState;	
SetParameterState:
	ton_nStep(IN:=TRUE,PT:=T#100MS);
	IF ton_nStep.Q AND NOT fbWriteParaStatus[0].Busy AND NOT fbWriteParaStatus[1].Busy AND NOT fbWriteParaStatus[2].Busy AND 
		NOT fbWriteParaStatus[3].BUSY AND NOT fbWriteParaStatus[4].BUSY  THEN
		nStep:=ReadParameter;
		fbwriteParameter[0].WRITE:=fbwriteParameter[1].WRITE:=fbwriteParameter[2].WRITE
		:=fbwriteParameter[3].WRITE:=fbwriteParameter[4].WRITE:=FALSE;
	ELSIF ton_nStep.Q AND (fbWriteParaStatus[0].Error OR fbWriteParaStatus[1].Error OR fbWriteParaStatus[2].Error OR
		fbWriteParaStatus[3].Error OR fbWriteParaStatus[4].Error) THEN
		nStep:=IndexHomeErrorState;
	END_IF
ReadParameter:
	fbReadParameter[0].READ:=fbReadParameter[1].READ:=fbReadParameter[2].READ:=
	fbReadParameter[3].READ:=fbReadParameter[4].READ:=TRUE;
	nStep:=ReadParameterState;
ReadParameterState:
	ton_nStep(IN:=TRUE,PT:=T#100MS);
	
	IF ton_nStep.Q AND NOT fbReadParaStatus[0].BUSY AND NOT fbReadParaStatus[1].BUSY AND NOT fbReadParaStatus[2].BUSY
		AND NOT fbReadParaStatus[3].BUSY AND NOT fbReadParaStatus[4].BUSY THEN
		fbReadParameter[0].READ:=fbReadParameter[1].READ:=fbReadParameter[2].READ:=
		fbReadParameter[3].READ:=fbReadParameter[4].READ:=FALSE;
		nStep:=AckParameter;
	ELSIF ton_nStep.Q AND (fbReadParaStatus[0].Error OR fbReadParaStatus[1].Error OR fbReadParaStatus[2].Error OR 
		fbReadParaStatus[3].Error OR fbReadParaStatus[4].Error) THEN
		nStep:=IndexHomeErrorState;
	END_IF
AckParameter:
	IF rTowardsVelActValue=rCMD_TowardsVelSetValue AND rOffVelActValue=rCMD_OffVelSetValue AND
		nHomeSensorActValue=nHomeSenorSetValue AND nHomeSynActValue=nHomeSynSetValue 
		AND nHomeActRefMode=nHomeSetRefMode  THEN
		nStep:=ExecuteToOrigin;
	ELSE
		nStep:=IndexHomeErrorState;
	END_IF
ExecuteToOrigin:
	mcHome.Execute:=TRUE;
	nStep:=HomeMonitorState;
HomeMonitorState:
	IF mcHome.Done THEN
		mcHome.Execute:=FALSE;
		nStep:=HomeMoveABS;
	ELSIF mcHome.Error OR axis.Status.Error THEN
		nStep:=IndexHomeErrorState;
	END_IF	
	IF eCMD_HomeDirection=MC_Direction.MC_Positive_Direction AND bCMD_NegativeLimit AND ton_HomErr.Q THEN
		mcReset.Execute:=TRUE;
		nStep:=IndexHomeErrorState;
	ELSIF eCMD_HomeDirection=MC_Direction.MC_Negative_Direction AND bCMD_PositiveLimit AND ton_HomErr.Q THEN
		mcReset.Execute:=TRUE;
		nStep:=IndexHomeErrorState;
	END_IF
HomeMoveABS:
	mcMoveAbs.Execute:=TRUE;	
	IF mcMoveAbs.Done THEN
		mcMoveAbs.Execute:=FALSE;
		nStep:=ExecuteHomeDone;
	ELSIF axis.Status.Error OR mcMoveAbs.Error THEN
		nStep:=IndexHomeErrorState;
	END_IF
ExecuteHomeDone:
	bResult_HomeBusy:=FALSE;
	bResult_HomeDone:=TRUE;
	nStep:=E_HomeStep.IndexHomeInital;
IndexHomeErrorState:
	bResult_HomeBusy:=FALSE;
	bResult_HomeDone:=FALSE;
	bResult_HomeError:=TRUE;
	mcHome.Execute:=FALSE;
	mcMoveAbs.Execute:=FALSE;
	nStep:=IndexHomeInital;
END_CASE
// 超时定时器
ton_HomErr(IN:=bResult_HomeBusy , PT:=T#20S , Q=> , ET=> );

ACT_AxisControl();
ACT_ErrorID();
ACT_Reset();
]]></ST>
    </Implementation>
